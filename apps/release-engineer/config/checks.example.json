{
  "commands": {
    "format": {
      "executable": "npm",
      "arguments": ["run", "format:check"],
      "timeoutMilliseconds": 120000
    },
    "test": {
      "executable": "npm",
      "arguments": ["test"],
      "timeoutMilliseconds": 120000
    },
    "build": {
      "executable": "npm",
      "arguments": ["run", "build"],
      "timeoutMilliseconds": 120000
    }
  },
  "requiredFiles": ["package.json", "README.md"]
}
