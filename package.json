{
  "name": "nolan-young-local-agent-laboratory",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false && tsc -p tsconfig.library.json --pretty false",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "validate:library": "tsx scripts/validate-agent-library.ts",
    "validate": "npm run validate:library && npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build",
    "agent": "tsx scripts/run-agent.ts",
    "agent:list": "tsx scripts/run-agent.ts --list",
    "clean": "tsx scripts/clean-generated-data.ts",
    "check:ollama": "tsx scripts/check-ollama.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/node": "^22.19.0",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3",
    "vitest": "^4.0.8"
  },
  "dependencies": {
    "exceljs": "^4.4.0"
  }
}
